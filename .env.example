# Dayby server environment.
# Copy to .env for local overrides. NEVER commit real secrets.
# docker-compose already provides sane defaults, so .env is optional for local dev.

# --- MongoDB ---
MONGODB_URI=mongodb://mongo:27017
DB_NAME=dayby

# --- Providers (mock needs no API keys; swap to a real provider later) ---
LLM_PROVIDER=mock
STT_PROVIDER=mock

# --- Auth ---
# Generate a strong random value before any real deployment.
JWT_SECRET=change-me-in-production

# --- App ---
APP_ENV=development
