# Dayby server environment.
# Copy to .env for local overrides. NEVER commit real secrets.
# docker-compose already provides sane defaults, so .env is optional for local dev.

# --- MongoDB ---
MONGODB_URI=mongodb://mongo:27017
DB_NAME=dayby

# --- Providers (mock needs no API keys) ---
LLM_PROVIDER=mock
# STT_PROVIDER=gemini transcribes real audio, in whatever language was actually
# spoken -- no locale to set, unlike on-device recognition.
STT_PROVIDER=mock

# --- Real Gemini (LLM and STT; handles Korean and any language) ---
# To enable, set LLM_PROVIDER=gemini / STT_PROVIDER=gemini and provide a key:
#   Option A (AI Studio):      GEMINI_API_KEY from https://aistudio.google.com/apikey
#   Option B (Vertex Express): set GOOGLE_GENAI_USE_VERTEXAI=true and use a Vertex AI api key
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.6-flash
GOOGLE_GENAI_USE_VERTEXAI=
# Milliseconds to wait on one model call before falling back. Without it a dropped
# connection is retried out of sight and the request never comes back.
GEMINI_TIMEOUT_MS=45000

# --- Auth ---
# AUTH_PROVIDER:
#   none   (default) no identity provider. The caller names its family with the
#          X-Family-Id header -- a bypass, not a login, so it only works when
#          APP_ENV=development.
#   mock   the whole sign-in flow with no keys: the token is just the email you
#          claim to be. Development only, for the same reason.
#   google real Google Sign-In. Verifies the ID token the app got from Google, so
#          GOOGLE_CLIENT_ID must be the same client the app signs in with.
AUTH_PROVIDER=none
GOOGLE_CLIENT_ID=

# Signs Dayby's own session tokens. Generate a strong random value before any real
# deployment: anyone who has it can mint a session for any account.
JWT_SECRET=change-me-in-production
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=60

# --- App ---
APP_ENV=development

# --- CORS ---
# Comma-separated browser origins allowed to call the API (the Flutter web client).
# "*" is fine for local dev; restrict before any real deployment.
CORS_ALLOW_ORIGINS=*
